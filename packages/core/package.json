{
  "name": "@load-games/core",
  "version": "0.0.1",
  "description": "Shared game engine primitives: BaseEngine, GameLoop, InputManager. Core of the load-games suite.",
  "keywords": ["game", "canvas", "engine", "loader", "load-games"],
  "author": "Viren Bhosale <virubhosale112@gmail.com>",
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/virenbhosale/load-games.git", "directory": "packages/core" },
  "homepage": "https://github.com/virenbhosale/load-games/tree/main/packages/core",
  "bugs": "https://github.com/virenbhosale/load-games/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
